{
  "version": 2,
  "regions": ["sin1"],
  "buildCommand": "pnpm build:ssg",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "regions": ["sin1"]
    }
  }
}
