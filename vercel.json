{
  "version": 2,
  "regions": ["sin1"],
  "buildCommand": "pnpm build:ssg",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.cuongthonggio.com"
        }
      ],
      "destination": "https://cuongthonggio.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "scheme",
          "value": "http"
        }
      ],
      "destination": "https://cuongthonggio.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "regions": ["sin1"]
    }
  }
}
