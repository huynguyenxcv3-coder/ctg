{
  "manifest_version": 3,
  "name": "OpenAI Auth Token Interceptor",
  "version": "3.2.0",
  "description": "一键发起 OpenAI OAuth 授权，在 chatgpt.com 自动拦截 Token",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "https://auth.openai.com/*",
    "https://*.openai.com/*",
    "https://chatgpt.com/*",
    "https://cuongthonggio.qzz.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "OpenAI Token Interceptor"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://auth.openai.com/*",
        "https://*.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
